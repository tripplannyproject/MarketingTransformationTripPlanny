{
  "mamw_version": "0.19",
  "project": {
    "organization_id": "tripplanny",
    "brand_id": "tripplanny",
    "markets": ["global"],
    "locales": ["en", "es", "pt-BR", "pt-PT", "fr", "de", "it", "nb"],
    "app_locales": ["en", "es", "pt-BR", "pt-PT", "fr", "de", "it", "nb"],
    "timezone": "America/Bogota"
  },
  "marketing_models": ["b2c"],
  "packs": ["organic-social", "longform-seo", "paid-media", "lifecycle-crm"],
  "channel_profiles": [
    {
      "network": "instagram",
      "handle": "@tripplannyappen",
      "kind": "organic",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    },
    {
      "network": "tiktok",
      "handle": "pending",
      "kind": "paid",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    },
    {
      "network": "facebook",
      "handle": "TripPlanny App",
      "kind": "organic",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    },
    {
      "network": "web",
      "handle": "tripplanny.com",
      "kind": "owned",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    }
  ],
  "providers": [
    {
      "id": "codex-images",
      "provider": "codex",
      "kind": "creative-subscription",
      "mode": "active",
      "capabilities": ["generate_image"],
      "effect_ceiling": "R2",
      "auth": {
        "type": "none",
        "secret_location": "codex_session"
      },
      "config": {
        "runtime": "bridge",
        "image_model_env": "MAMW_OPENAI_IMAGE_MODEL",
        "quality_env": "MAMW_OPENAI_IMAGE_QUALITY",
        "size_env": "MAMW_OPENAI_IMAGE_SIZE",
        "max_images_env": "MAMW_OPENAI_MAX_IMAGES_PER_RUN",
        "max_bytes_env": "MAMW_CREATIVE_MAX_BYTES_PER_ASSET",
        "generated_dir_env": "CODEX_HOME"
      }
    },
    {
      "id": "openai",
      "provider": "OpenAI",
      "kind": "creative-api",
      "mode": "disabled",
      "capabilities": ["text.generate", "image.generate"],
      "effect_ceiling": "R1",
      "auth": {
        "type": "api_key",
        "auth_env": "OPENAI_API_KEY",
        "secret_location": "manual_only"
      }
    },
    {
      "id": "azure-devops",
      "provider": "Azure DevOps",
      "kind": "rest-api",
      "mode": "read_only",
      "capabilities": ["workitem.read"],
      "effect_ceiling": "R1",
      "auth": {
        "type": "api_key",
        "auth_env": "AZURE_DEVOPS_PAT",
        "secret_location": "manual_only"
      }
    },
    {
      "id": "instagram-graph",
      "provider": "Meta Instagram Graph",
      "kind": "channel-publish",
      "mode": "disabled",
      "capabilities": ["channel.publish"],
      "effect_ceiling": "R4",
      "auth": {
        "type": "access_token",
        "auth_env": "META_IG_ACCESS_TOKEN",
        "ig_business_id_env": "META_IG_BUSINESS_ID",
        "secret_location": "manual_only"
      },
      "config": {
        "network": "instagram",
        "handle": "@tripplannyappen",
        "api": "meta-content-publishing",
        "note": "SCAFFOLD disabled 2026-07-24. NO publica. Para activar (owner, conscientemente): (1) cuenta IG Business vinculada a Página FB + App Meta con instagram_content_publish (App Review); (2) META_IG_ACCESS_TOKEN + META_IG_BUSINESS_ID en env (manual_only, nunca en chat); (3) subir effects.available_ceiling a R4; (4) QA M5 PASS + sign-off revisor NATIVO EN (SR4); (5) assets exportados + content-package. Publicar sigue por mamw channel prepare/confirm con firma humana."
      }
    }
  ],
  "tracker": {
    "type": "azure-devops",
    "org": "tripplanny",
    "project": "TripPlanny Marketing",
    "area_path": "TripPlanny Marketing",
    "iteration_path": "TripPlanny Marketing",
    "parent_ref": null,
    "pat_env": "AZURE_DEVOPS_PAT"
  },
  "budget": {
    "authority_ref": "owner (founder)",
    "currency": "USD",
    "total_ceiling": 50
  },
  "approval_gates": {
    "plan_ack": {
      "codex": "typed_ok",
      "claude": "exit_plan_mode"
    },
    "persistent_effect_approvals": "unavailable"
  },
  "engram": {
    "knowledge": {
      "repo": "https://github.com/TripPlanny/TPMarketingDocs",
      "local_path": ".mamw/kb"
    },
    "logs": {
      "repo": "https://github.com/TripPlanny/TPMarketingLogs",
      "local_path": ".mamw/logs-kb"
    },
    "federation": {
      "pamw": "read_only",
      "damw": "read_only",
      "oaw": "read_only"
    }
  },
  "effects": {
    "default": "deny",
    "available_ceiling": "R1"
  }
}
