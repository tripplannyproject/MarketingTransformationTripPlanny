      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    },
    {
      "network": "facebook",
      "handle": "TripPlanny App",
      "kind": "organic",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    },
    {
      "network": "web",
      "handle": "tripplanny.com",
      "kind": "owned",
      "status": "active",
      "cadence": "pending",
      "baseline": "pending"
    }
  ],
  "providers": [
    {
      "id": "openai",
      "provider": "OpenAI",
      "kind": "creative-api",
      "mode": "disabled",
      "capabilities": ["text.generate", "image.generate"],
      "effect_ceiling": "R1",
      "auth": {
        "type": "api_key",
        "auth_env": "OPENAI_API_KEY",
        "secret_location": "manual_only"
      }
    },
    {
      "id": "azure-devops",
      "provider": "Azure DevOps",
      "kind": "rest-api",
      "mode": "read_only",
      "capabilities": ["workitem.read"],
      "effect_ceiling": "R1",
      "auth": {
        "type": "api_key",
        "auth_env": "AZURE_DEVOPS_PAT",
        "secret_location": "manual_only"
      }
    }
  ],
  "tracker": {
    "type": "azure-devops",
    "org": "tripplanny",
    "project": "TripPlanny Marketing",
    "area_path": "TripPlanny Marketing",
    "iteration_path": "TripPlanny Marketing",
    "parent_ref": null,
    "pat_env": "AZURE_DEVOPS_PAT"
  },
  "budget": {
    "authority_ref": "owner (founder)",
    "currency": "USD",
    "total_ceiling": 50
  },
  "approval_gates": {
    "plan_ack": {
      "codex": "typed_ok",
      "claude": "exit_plan_mode"
    },
    "persistent_effect_approvals": "unavailable"
  },
  "engram": {
    "knowledge": {
      "repo": "https://github.com/TripPlanny/TPMarketingDocs",
      "local_path": ".mamw/kb"
