{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tripplanny.dev/mamw/schemas/creative-design-v1.schema.json",
  "title": "MAMW creative design v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "design_id",
    "design_version",
    "status",
    "scope",
    "lineage",
    "objective",
    "concept",
    "visual_system",
    "copy_system",
    "placements",
    "locales",
    "reference_manifest_ref",
    "generation_policy",
    "qa_rubric"
  ],
  "properties": {
    "schema_version": { "const": "creative-design-v1" },
    "design_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$" },
    "design_version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "in_review", "approved", "superseded"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization_id", "brand_id", "market_ids", "account_scope"],
      "properties": {
        "organization_id": { "type": "string", "minLength": 1 },
        "brand_id": { "type": "string", "minLength": 1 },
        "market_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2 } },
        "account_scope": { "type": "string", "minLength": 1 }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaign_ref", "brand_dna_hash", "storytelling_hash", "brief_hash"],
      "properties": {
        "campaign_ref": { "type": "string", "minLength": 1 },
        "work_item_ref": { "type": "string", "minLength": 1 },
        "brand_dna_hash": { "$ref": "#/$defs/hash" },
        "storytelling_hash": { "$ref": "#/$defs/hash" },
        "brief_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audience", "desired_change", "single_minded_proposition", "proof"],
      "properties": {
        "audience": { "type": "string", "minLength": 1 },
        "desired_change": { "type": "string", "minLength": 1 },
        "single_minded_proposition": { "type": "string", "minLength": 1 },
        "proof": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "claims_allowed": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "claims_forbidden": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["insight", "central_idea", "story_spine", "distinctive_elements", "avoid"],
      "properties": {
        "insight": { "type": "string", "minLength": 1 },
        "central_idea": { "type": "string", "minLength": 1 },
        "story_spine": { "type": "string", "minLength": 1 },
        "distinctive_elements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "avoid": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "visual_system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "scene", "composition", "palette", "style", "lighting", "continuity", "deterministic_layers"],
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "scene": { "type": "string", "minLength": 1 },
        "composition": { "type": "string", "minLength": 1 },
        "palette": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "style": { "type": "string", "minLength": 1 },
        "lighting": { "type": "string", "minLength": 1 },
        "continuity": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "deterministic_layers": { "type": "array", "uniqueItems": true, "items": { "enum": ["logo", "overlay_text", "cta", "legal", "price", "subtitles", "none"] } }
      }
    },
    "copy_system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voice_tone", "text_render_policy", "locale_copy_refs"],
      "properties": {
        "voice_tone": { "type": "string", "minLength": 1 },
        "text_render_policy": { "enum": ["deterministic_only", "model_may_suggest_no_final_text"] },
        "locale_copy_refs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "placements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["placement_id", "platform", "surface", "width", "height", "safe_zones_ref"],
        "properties": {
          "placement_id": { "type": "string", "minLength": 1 },
          "platform": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "duration_seconds": { "type": "number", "exclusiveMinimum": 0 },
          "safe_zones_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["locale", "market", "adaptation_mode", "locale_profile_ref", "market_dna_hash", "native_review_required"],
        "properties": {
          "locale": { "$ref": "#/$defs/locale" },
          "market": { "type": "string", "minLength": 2 },
          "adaptation_mode": { "enum": ["translation", "localization", "transcreation", "native"] },
          "locale_profile_ref": { "type": "string", "minLength": 1 },
          "market_dna_hash": { "$ref": "#/$defs/hash" },
          "native_review_required": { "type": "boolean" },
          "visual_adaptation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reference_manifest_ref": { "type": "string", "minLength": 1 },
    "generation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_profile", "capability", "max_attempts", "max_assets", "currency", "run_ceiling", "authority_ref", "fallback"],
      "properties": {
        "provider_profile": { "type": "string", "minLength": 1 },
        "capability": { "enum": ["generate_image", "edit_image"] },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 20 },
        "max_assets": { "type": "integer", "minimum": 1, "maximum": 100 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "run_ceiling": { "type": "number", "minimum": 0 },
        "authority_ref": { "type": "string", "minLength": 1 },
        "fallback": { "enum": ["deny", "same_provider_only", "approved_allowlist"] }
      }
    },
    "qa_rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brand", "storytelling", "originality", "reference_fidelity", "rights", "locale", "accessibility", "platform"],
      "properties": {
        "brand": { "type": "string", "minLength": 1 },
        "storytelling": { "type": "string", "minLength": 1 },
        "originality": { "type": "string", "minLength": 1 },
        "reference_fidelity": { "type": "string", "minLength": 1 },
        "rights": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "accessibility": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 }
      }
    },
    "approval_ref": { "type": "string", "minLength": 1 },
    "approved_design_hash": {
      "description": "SHA-256 of the canonical design payload excluding status, approval_ref and approved_design_hash.",
      "$ref": "#/$defs/hash"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } }, "required": ["status"] },
      "then": { "required": ["approval_ref", "approved_design_hash"] }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "locale": { "type": "string", "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$" }
  }
}
