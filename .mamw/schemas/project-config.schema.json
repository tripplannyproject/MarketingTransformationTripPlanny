{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tripplanny.dev/mamw/schemas/project-config.schema.json",
  "title": "MAMW project installation metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["mamw_version", "project_id", "project_name", "mirror", "security", "source"],
  "properties": {
    "mamw_version": { "const": "0.15" },
    "project_id": { "type": "string", "minLength": 1 },
    "project_name": { "type": "string", "minLength": 1 },
    "base_branch": { "type": "string", "minLength": 1 },
    "mirror": { "enum": ["codex", "claude", "both"] },
    "installed_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "runtime_contract": {
      "type": "object",
      "required": ["codex", "claude", "claude_skill_form"],
      "properties": {
        "codex": { "const": "$mm-start" },
        "claude": { "const": "/mm:start" },
        "claude_skill_form": { "const": "/mm-start" }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enforcement_profile", "managed_policy_required_for_enterprise"],
      "properties": {
        "enforcement_profile": { "enum": ["local_guardrails", "managed_enforcement"] },
        "managed_policy_required_for_enterprise": { "const": true },
        "managed_policy_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reference", "verified_at", "verified_by", "runtimes"],
          "properties": {
            "reference": { "type": "string", "minLength": 1 },
            "verified_at": { "type": "string", "format": "date-time" },
            "verified_by": { "type": "string", "minLength": 1 },
            "runtimes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["codex", "claude"] }
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "enforcement_profile": { "const": "managed_enforcement" } } },
          "then": { "required": ["managed_policy_evidence"] }
        }
      ]
    },
    "engram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "knowledge_repo": { "type": ["string", "null"] },
        "logs_repo": { "type": ["string", "null"] }
      }
    },
    "source": {
      "type": "object",
      "required": ["cli_package", "framework_version"],
      "properties": {
        "cli_package": { "const": "@tripplanny/mamw-cli" },
        "framework_version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
