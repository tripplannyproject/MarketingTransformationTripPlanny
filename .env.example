# MAMW non-secret runtime defaults.
MAMW_LOG_LEVEL=info
MAMW_DEFAULT_TIMEZONE=America/Bogota

# Image generation runs on the Codex subscription (mamw-codex-creative, gpt-image-2) — it needs NO
# OPENAI_API_KEY. Do NOT add one here or to .env.local: its presence switches Codex to API billing.
MAMW_OPENAI_IMAGE_MODEL=gpt-image-2
MAMW_OPENAI_IMAGE_QUALITY=auto
MAMW_OPENAI_IMAGE_SIZE=auto

# Local MAMW run guards. These limits do not authorize spend by themselves.
MAMW_OPENAI_MAX_IMAGES_PER_RUN=4
MAMW_OPENAI_MAX_COST_USD_PER_RUN=10.00

# Azure DevOps work-item tracker (org/project routing). Referenced by tracker.pat_env in
# mamw.config.json. The PAT is a secret: set it from a private terminal or .env.local, never here.
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# Provider OAuth tokens and API keys belong in a secret store or untracked .env.local file.
# Never paste them into chat, client-side code, tracked config, prompts, logs or receipts.
# MAMW provider settings added by init
META_IG_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
IG_USER_ID_TRIPPLANNYAPP=
IG_USER_ID_TRIPPLANNYAPPEN=
# MAMW provider settings added by init
MAMW_CREATIVE_MAX_BYTES_PER_ASSET=8388608
