{
  "mamw_version": "0.19",
  "project": {
    "organization_id": "org-example",
    "brand_id": "brand-example",
    "markets": [
      "CO"
    ],
    "locales": [
      "es-CO"
    ],
    "timezone": "America/Bogota"
  },
  "marketing_models": [
    "b2c"
  ],
  "packs": [],
  "channel_profiles": [],
  "providers": [
    {
      "id": "codex-images",
      "provider": "codex",
      "kind": "creative-subscription",
      "mode": "disabled",
      "capabilities": [
        "generate_image"
      ],
      "effect_ceiling": "R2",
      "auth": {
        "type": "none",
        "secret_location": "codex_session"
      },
      "config": {
        "runtime": "auto",
        "image_model_env": "MAMW_OPENAI_IMAGE_MODEL",
        "quality_env": "MAMW_OPENAI_IMAGE_QUALITY",
        "size_env": "MAMW_OPENAI_IMAGE_SIZE",
        "max_images_env": "MAMW_OPENAI_MAX_IMAGES_PER_RUN",
        "max_bytes_env": "MAMW_CREATIVE_MAX_BYTES_PER_ASSET",
        "generated_dir_env": "CODEX_HOME"
      }
    }
  ],
  "tracker": {
    "type": "azure-devops",
    "org": "${AZURE_DEVOPS_ORG}",
    "project": "${AZURE_DEVOPS_PROJECT}",
    "area_path": "",
    "iteration_path": "",
    "parent_ref": null,
    "pat_env": "AZURE_DEVOPS_PAT"
  },
  "budget": {
    "authority_ref": "unknown",
    "currency": "COP",
    "total_ceiling": null
  },
  "approval_gates": {
    "plan_ack": {
      "codex": "typed_ok",
      "claude": "exit_plan_mode"
    },
    "persistent_effect_approvals": "available"
  },
  "engram": {
    "knowledge": {
      "repo": null,
      "local_path": ".mamw/kb"
    },
    "logs": {
      "repo": null,
      "local_path": ".mamw/logs-kb"
    },
    "federation": {
      "pamw": "read_only",
      "damw": "read_only",
      "oaw": "read_only"
    }
  },
  "effects": {
    "default": "deny",
    "available_ceiling": "R1"
  }
}
